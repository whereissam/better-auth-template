# API URLs
VITE_API_URL=http://localhost:4200
VITE_APP_URL=http://localhost:4000
# Optional (for HTTPS tunnel dev): comma-separated hostnames for Vite dev server
# Example: VITE_ALLOWED_HOSTS=your-subdomain.ngrok-free.app,abc.trycloudflare.com
VITE_ALLOWED_HOSTS=

# WalletConnect (Required for SIWE)
# Get your project ID at https://cloud.walletconnect.com
VITE_WALLETCONNECT_PROJECT_ID=your_project_id

# Auth providers are auto-detected from backend credentials.
# No feature flags needed — set GOOGLE_CLIENT_ID etc. in backend/.env
# and the frontend will automatically enable/disable buttons.
